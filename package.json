{
  "name": "xlsx-json-converter-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @glitches/xlsx-json-converter run build",
    "test": "pnpm --filter tests run test",
    "test:coverage": "pnpm --filter tests run test:coverage",
    "lint": "oxlint packages",
    "lint:fix": "oxlint packages --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "pnpm -r run typecheck",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@types/node": "catalog:development",
    "lint-staged": "catalog:lint",
    "oxfmt": "catalog:lint",
    "oxlint": "catalog:lint",
    "simple-git-hooks": "catalog:lint",
    "typescript": "catalog:development"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
